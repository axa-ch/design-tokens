{
  "name": "@axa-ch/design-tokens",
  "version": "3.2.0",
  "type": "module",
  "description": "AXA Design Tokens",
  "main": "./tokens.js",
  "module": "./tokens.mjs",
  "types": "./tokens.d.ts",
  "keywords": [
    "design tokens",
    "css",
    "scss",
    "js",
    "AXA",
    "styling"
  ],
  "files": [
    "build",
    "tokens",
    "tailwind.config.js",
    "tokens.js",
    "tokens.cjs",
    "tokens.d.ts",
    "tokens.json",
    "tokens.scss",
    "tokens.css",
    "tokens.min.css",
    "tailwind-theme.css"
  ],
  "exports": {
    ".": {
      "types": "./tokens.d.ts",
      "import": "./tokens.js",
      "require": "./tokens.cjs"
    },
    "./build/": "./build/",
    "./tokens.json": "./tokens.json",
    "./tokens.css": "./tokens.css",
    "./tokens.min.css": "./tokens.min.css",
    "./tokens.scss": "./tokens.scss",
    "./tailwind.config": "./tailwind.config.js",
    "./tailwind-theme": "./tailwind-theme.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axa-ch/design-tokens"
  },
  "scripts": {
    "pretest": "npm run build",
    "lint": "prettier --ignore-path .prettierignore . --check && biome lint .",
    "test": "npm run lint && sass tests/mixins.spec.scss tests/mixins.spec.css && vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rimraf build",
    "prebuild": "npm run clean",
    "build": "vite-node build.ts && prettier --write --ignore-path .prettierignore tokens.json build && vite build",
    "postbuild": "tsc",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "start": "npm run build && npm run storybook"
  },
  "author": "AXA (https://axa.ch)",
  "maintainers": [
    {
      "name": "Gianluca Guarini",
      "email": "gianluca.guarini@axa.ch"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@axa-ch/easy-config": "^4.0.1",
    "@csstools/postcss-global-data": "^4.0.0",
    "@divriots/style-dictionary-to-figma": "^0.4.0",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-links": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@storybook/testing-library": "^0.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "chaestli": "^3.1.0",
    "clsx": "^2.1.1",
    "color-blend": "^4.0.0",
    "color-util": "^2.2.3",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "postcss": "^8.5.8",
    "postcss-custom-media": "^12.0.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "storybook": "^10.3.1",
    "style-dictionary": "^5.4.0",
    "style-dictionary-utils": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.0"
  }
}
